COMPOSE_PROJECT_NAME=nutricore
APP_NAME=NutriCore
APP_ENV=development

API_PORT=8000
WEB_PORT=3000
TRAEFIK_PORT=80
TRAEFIK_TLS_PORT=443
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

PUBLIC_BASE_DOMAIN=example.com
TRAEFIK_ACME_EMAIL=ops@example.com

POSTGRES_DB=nutricore
POSTGRES_USER=nutricore
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password

API_BASE_URL=http://api.localhost
NEXT_PUBLIC_API_BASE_URL=http://api.localhost
NUTRICORE_JWT_SECRET=change-this-jwt-secret
NUTRICORE_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
NUTRICORE_BOOTSTRAP_ADMIN_ENABLED=true
NUTRICORE_BOOTSTRAP_ADMIN_NAME="NutriCore Admin"
NUTRICORE_BOOTSTRAP_ADMIN_EMAIL=admin@nutricore.app
NUTRICORE_BOOTSTRAP_ADMIN_PASSWORD=change-this-admin-password

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password

TRAEFIK_ADMIN_USER=admin
TRAEFIK_ADMIN_PASSWORD=change-me-admin

BACKUP_DIR=infra/backups
BACKUP_RETENTION_DAYS=7
BACKUP_ENCRYPTION_PASSPHRASE=change-this-backup-passphrase
